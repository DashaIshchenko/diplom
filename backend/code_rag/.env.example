# ============================================================================
# CODE RAG MODULE - ENVIRONMENT VARIABLES
# ============================================================================

# Application Settings
# ============================================================================
APP_NAME=code-rag
APP_ENV=development
LOG_LEVEL=INFO

# Directories
# ============================================================================
DATA_DIR=./data
REPO_BASE_PATH=./data/repositories
CACHE_DIR=./data/cache

# Git Settings - GitHub
# ============================================================================
GITHUB_TOKEN=

# Git Settings - GitLab
# ============================================================================
GITLAB_TOKEN=

# Git Settings - Azure DevOps
# ============================================================================
# Основное подключение
AZURE_DEVOPS_BASE_URL=https://url_company/tfs
AZURE_DEVOPS_COLLECTION=DefaultCollection
AZURE_DEVOPS_PAT=your_personal_access_token_here
AZURE_DEVOPS_ORGANIZATION=

# Множественные Azure DevOps подключения (JSON формат)
# Используйте это если нужно работать с несколькими Azure DevOps инстансами
# AZURE_CONNECTIONS=[{"name": "company1", "base_url": "https://dev.azure.com/org1", "collection": "DefaultCollection", "pat": "token1"}, {"name": "company2", "base_url": "https://company2.visualstudio.com", "collection": "MyCollection", "pat": "token2"}]

# SSH Key Path (для приватных репозиториев через SSH)
# ============================================================================
SSH_KEY_PATH=~/.ssh/id_rsa

# Embedding Model Settings
# ============================================================================
DEFAULT_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# Nomic Embed Settings
# ============================================================================
NOMIC_MODEL_PATH=nomic-ai/nomic-embed-text-v1.5
NOMIC_DIMENSION=768
NOMIC_MAX_TOKENS=8192
# Matryoshka dimension (опционально, для сжатия: 64, 128, 256, 512)
# NOMIC_MATRYOSHKA_DIM=256

# Qwen Embed Settings (если используется Qwen)
# ============================================================================
QWEN_MODEL_SIZE=0.6B
QWEN_DIMENSION=2000
QWEN_MAX_TOKENS=4096

# Qdrant Settings
# ============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=code_embeddings
QDRANT_USE_HTTPS=false

# Vector DB Configuration
# ============================================================================
VECTOR_SIZE=768
DISTANCE_METRIC=cosine

# Repository Monitor Settings
# ============================================================================
MONITOR_CHECK_INTERVAL=300
MONITOR_AUTO_START=false

# API Settings
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# LLM Settings (для Qwen-coder)
# ============================================================================
LLM_MODEL_PATH=Qwen/Qwen2.5-Coder-7B-Instruct
LLM_DEVICE=cuda
LLM_MAX_NEW_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95

# Performance Settings
# ============================================================================
MAX_WORKERS=4
BATCH_SIZE=32
CHUNK_SIZE=512

# Cache Settings
# ============================================================================
ENABLE_CACHE=true
CACHE_TTL=3600

# Logging
# ============================================================================
LOG_FILE=./logs/code_rag.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# RAG Settings
# ============================================================================
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7
RAG_EXPAND_QUERY=true
RAG_USE_DUAL_EMBEDDINGS=true
